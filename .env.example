# ============================================================
# Stock Manager Backend — Environment Variables
# ============================================================

# --- Paths (FR-B05) ---
# PM-MCP codebase root. Defaults to repo root when unset.
PM_MCP_ROOT=

# --- LLM (FR-B02, FR-B03, FR-B14) ---
# Google AI Studio API key — sent via `x-goog-api-key` header (never URL).
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Module-level default model (used by ad-hoc summarize_text /
# _call_gemma direct callers). The chat + analysis-report pipelines
# pin themselves to CHAT_MODEL below regardless of this value.
GEMINI_MODEL=gemini-2.5-flash

# Chat-bot + analysis-report shared default. ``gemini-3.0-flash`` was
# requested earlier but a live probe confirmed it 404s on the v1beta
# endpoint (not GA on this API tier yet); 2.5-flash is the newest model
# that actually answers. Preview/experimental models are gated by
# CHAT_USE_PREVIEW.
CHAT_MODEL=gemini-2.5-flash
CHAT_USE_PREVIEW=0

# Resilient fallback chain: when the primary model returns 429 / 503 /
# 404 / circuit-open, the wrapper walks this list. Every entry has been
# probed against /v1beta/models/{name} and returns 200; the legacy
# ``gemini-1.5-flash-latest`` and ``gemini-1.5-pro`` were removed
# because both 404 on this tier.
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-2.5-flash-lite

# Output token budget — Korean Markdown reports were getting truncated
# at the legacy 2048 default; 8192 fits a typical 500-word KO report.
LLM_MAX_OUTPUT_TOKENS=8192

# LLM_TIMEOUT_SEC overrides Timeout.GEMINI (default 300).
LLM_TIMEOUT_SEC=300

# --- Security / Networking (FR-B01, FR-B04) ---
# Comma-separated CORS allow_origins. Wildcard "*" disables credentials.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Rate limit per client IP.
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_ANALYSIS_PER_MIN=10

# --- Ops ---
LOG_LEVEL=INFO
ENVIRONMENT=dev

# --- Optional data providers ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_CALL_DELAY=15
SEC_EDGAR_USER_AGENT=
OBSIDIAN_VAULT_PATH=./obsidian_vault

# --- Legacy alias (kept for backward compatibility; prefer GEMINI_MODEL) ---
GEMMA_MODEL=gemini-2.5-flash
